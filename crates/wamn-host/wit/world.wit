package wamn:host@0.1.0;

/// Host-side bindgen world for the wamn:postgres plugin (S1: stub; real
/// implementation lands with S2). Imports = interfaces the host implements.
world postgres-plugin {
  import wamn:postgres/types@0.1.0;
  import wamn:postgres/client@0.1.0;
}

/// Host-side bindgen world for the wamn:node control interface (cooperative
/// cancellation). payloads is deliberately not registered (5.10); credentials
/// is the vault plugin below (5.9).
world node-plugin {
  import wamn:node/control@0.1.0;
}

/// Host-side bindgen world for the wamn:node credentials vault (5.9): the
/// host IMPLEMENTS `get` — per-project resolution from a mounted static
/// source, grant-enforced (cjv.3) and audit-logged. The trusted
/// `wamn:runner/credentials.set-granted` (cjv.3) lets the compiled-in
/// flow-runner declare its per-run grant so the host can enforce the frozen
/// `not-granted` grant on that single long-lived component. See
/// plugins/wamn_credentials.rs.
world credentials-plugin {
  import wamn:node/credentials@0.1.0;
  import wamn:runner/credentials@0.1.0;
}

/// Host-side bindgen world for the S4 `nodebench` / `serve-node` harness: the
/// host CALLS a bench node's exported `handler.run` and IMPLEMENTS the bench
/// `wait-ns` import (a real async host sleep) used to model an I/O-bound node
/// uniformly across guest languages. See docs/p0-exit-criteria.md S4.
world node-bench {
  import wamn:nodebench/host@0.1.0;
  export wamn:node/handler@0.1.0;
}

/// Host-side bindgen world for the S5 `wamn:logging` plugin: the host
/// IMPLEMENTS `wasi:logging/logging` (enrich + non-blocking enqueue + drop
/// counter), routing guest logs to an OTLP LoggerProvider the plugin owns. See
/// docs/p0-exit-criteria.md S5.
world logging-plugin {
  import wasi:logging/logging@0.1.0-draft;
}
