    "input": { "hold": { "material": "resin-A", "moisture_pct": "6.00", "moisture_max_pct": "5.00" } },
    "expect": [
      { "subset": { "recommended": "use-as-is" } }
    ]
  },
  {
    "schema-version": "0.1",
    "name": "disposition-accept",
    "node-ref": {},
    "input": { "hold": { "material": "resin-A", "moisture_pct": "4.00", "moisture_max_pct": "5.00" } },
    "expect": [
      { "subset": { "recommended": "accept" } }
    ]
  },
  {
    "schema-version": "0.1",
    "name": "disposition-invalid-input",
    "node-ref": {},
    "input": { "hold": { "material": "resin-A", "moisture_pct": "not-a-decimal", "moisture_max_pct": "5.00" } },
    "expect": [
      { "error-class": { "node-error": "invalid-input" } }
    ]
  },
  {
    "schema-version": "0.1",
