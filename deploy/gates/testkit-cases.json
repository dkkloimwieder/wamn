    "expect": [
      { "subset": { "recommended": "reject" } },
      { "path-equals": { "pointer": "/recommended", "value": "reject" } },
      { "port": "main" }
    ]
  },
  {
    "schema-version": "0.1",
    "name": "disposition-use-as-is",
