      { "egress": { "flow": "tk-runworker", "calls": { "count": 1 } } },
      { "egress": { "flow": "tk-runworker", "calls": "none-denied" } },
      { "db-state": { "query": "SELECT to_jsonb(t) FROM sink t", "params": [], "expect": { "row-count": 1 } } }
    ]
  }
