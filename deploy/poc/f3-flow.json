{
  "schema-version": "0.1",
  "flow-id": "escalate-stale-holds",
  "version": 1,
  "name": "F3 escalate-stale-holds (nightly cron)",
  "trigger": { "type": "cron", "schedule": "0 2 * * *" },
  "entry": "shift",
  "credentials": [
    {
      "name": "notify-webhook",
      "kind": "api-key",
      "description": "The manager notification webhook secret — resolved by the vault (5.9) at dispatch, never inlined here."
    }
  ],
  "nodes": [
    {
      "id": "shift",
      "type": "time-shift",
      "label": "cutoff = fire-at-ms - 48h",
      "config": { "base": "\"fire-at-ms\"", "offset-ms": -172800000, "format": "iso", "key": "cutoff" }
    },
    {
      "id": "list-stale",
      "type": "postgres",
      "label": "open holds older than the cutoff",
      "config": {
        "entity": "quality_holds",
        "op": "list",
        "filters": { "status": "eq.open", "opened_at": "lt.{{cutoff}}" },
        "sort": "opened_at",
        "limit": 500
      }
    },
    {
      "id": "gate",
      "type": "conditional",
      "label": "any stale hold left?",
      "config": { "expression": "length(@) > `0`" }
    },
    {
      "id": "escalate",
      "type": "postgres",
      "label": "mark the head hold escalated",
      "config": { "entity": "quality_holds", "op": "update", "id": "[0].id", "body": "{status: 'escalated'}" }
    },
    {
      "id": "notify",
      "type": "http-request",
      "label": "notify manager (credentialed webhook)",
      "credential": "notify-webhook",
      "config": {
        "method": "POST",
        "url": "https://notify.example/holds",
        "body": "{hold: id, status: status, opened_at: opened_at, message: 'quality hold escalated past 48h'}"
      }
    },
    {
      "id": "advance",
      "type": "transform",
      "label": "drop the head, loop on the tail",
      "config": { "expression": "[1:]" }
    },
    { "id": "done", "type": "respond", "label": "no stale holds remain" }
  ],
  "edges": [
    { "from": "shift", "to": "list-stale" },
    { "from": "list-stale", "to": "gate" },
    { "from": "gate", "from-port": "true", "to": "escalate" },
    { "from": "gate", "from-port": "true", "to": "advance" },
    { "from": "escalate", "to": "notify" },
    { "from": "advance", "to": "gate" },
    { "from": "gate", "from-port": "false", "to": "done" }
  ],
  "allowed-hosts": ["notify.example"]
}
