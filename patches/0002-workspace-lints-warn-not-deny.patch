diff --git a/Cargo.toml b/Cargo.toml
index c2cd180..07ecbc3 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -17,7 +17,11 @@ version = "2.5.1"
 rust-version = "1.94.0"
 
 [workspace.lints.rust]
-warnings = 'deny' # Treat all warnings as errors
+# wamn carried patch: 'warn', not 'deny'. As a git dependency cargo builds
+# this crate with --cap-lints=allow; as a [patch] path dependency it gets the
+# full lint set, and wamn's feature subset (no default features) legitimately
+# leaves some upstream code unused. Restore the git-dep behavior.
+warnings = 'warn'
 unsafe_code = 'deny'
 # Inherited from Wasmtime
 unused_extern_crates = 'warn'
